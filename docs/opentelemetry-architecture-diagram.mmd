graph TB
    subgraph "Data Sources"
        subgraph "Traces Sources"
            APP1[Applications with<br/>Auto-Instrumentation<br/>Java/Python/Node.js/.NET/Go]
            JAEGER_CLIENT[Jaeger Clients<br/>Legacy Apps]
            ZIPKIN_CLIENT[Zipkin Clients<br/>Legacy Apps]
            OTLP_CLIENT[OTLP Instrumented<br/>Applications]
        end

        subgraph "Metrics Sources"
            subgraph "OTel Collected"
                HOST[Host Metrics<br/>System Stats<br/>CPU/Memory/Disk/Network]
                OTLP_APPS[OTLP Apps<br/>Custom Metrics]
            end
            subgraph "Prometheus Scraped"
                K8S_METRICS[K8s Components<br/>API/Scheduler/Controller]
                KUBELET[Kubelet/cAdvisor<br/>container_* metrics]
                NODE_EXPORTER[Node Exporter<br/>node_* metrics]
                KSM[Kube-State-Metrics<br/>kube_* metrics]
            end
        end

        subgraph "Logs Sources"
            K8S_PODS[Kubernetes Pods<br/>/var/log/pods]
            K8S_EVENTS[Kubernetes Events<br/>Events API]
            OS_ALL[OpenStack Services<br/>17 services consolidated<br/>Nova/Neutron/Cinder<br/>Keystone/Glance/Horizon<br/>Heat/Swift/Octavia<br/>Placement/Manila/Ironic<br/>Barbican/Ceilometer<br/>Gnocchi/Skyline/Trove]
        end
    end

    subgraph "OpenTelemetry Collector DaemonSet"
        subgraph "Receivers Layer"
            subgraph "Trace Receivers"
                OTLP_GRPC[OTLP gRPC<br/>:4317]
                OTLP_HTTP[OTLP HTTP<br/>:4318]
                JAEGER_GRPC[Jaeger gRPC<br/>:14250]
                JAEGER_HTTP[Jaeger HTTP<br/>:14268]
                JAEGER_COMPACT[Jaeger Compact<br/>:6831/UDP]
                ZIPKIN[Zipkin<br/>:9411]
            end

            subgraph "Metrics Receivers"
                OTLP_METRICS[OTLP Receiver<br/>:4317/:4318]
                HOSTMETRICS[Host Metrics<br/>Receiver<br/>✅ Active]
                KUBELETSTATS_DISABLED[Kubelet Stats<br/>❌ DISABLED<br/>Use Prometheus instead]
            end

            subgraph "Logs Receivers"
                FILELOG_K8S[filelog/k8s_containers<br/>CRI Parser]
                K8SOBJECTS[k8sobjects<br/>Events Receiver]
                FILELOG_OS[filelog/openstack<br/>CONSOLIDATED<br/>All 17 services<br/>Dynamic service extraction]
            end
        end

        subgraph "Processors Layer"
            MEMORY_LIMITER[Memory Limiter<br/>90% limit, 25% spike]
            BATCH[Batch Processor<br/>1000 batch, 10s timeout]
            NODE_LABELS[attributes/<br/>add-node-labels<br/>k8s_node_name + host_name]
            K8S_ATTRS[k8sattributes<br/>Pod/Namespace/Node<br/>Labels + Annotations]
            RESOURCE_DETECT[resourcedetection/env<br/>env, k8snode, system]
            RESOURCE_HOSTNAME[resource/hostname<br/>k8s.node.name → host.name]
            RESOURCE_OS[resource/openstack<br/>service.namespace=openstack]
            RESOURCE_K8S[resource/k8s<br/>service.namespace=kube-system]
            RESOURCE_K8S_EVENTS[resource/k8s-events<br/>log_type=k8s-event]
            RESOURCE_LOKI[resource/loki-labels<br/>OTel → Loki mapping]
            ATTRS[attributes<br/>cluster + environment]
        end

        subgraph "Exporters Layer"
            DEBUG[Debug Exporter<br/>Sampling: 2 initial<br/>1/1000 thereafter]
            TEMPO_EXP[otlp/tempo<br/>tempo:4317]
            PROM_RW[prometheusremotewrite<br/>prometheus:9090/api/v1/write]
            LOKI_EXP[otlphttp/loki<br/>loki-gateway/otlp]
        end
    end

    subgraph "Prometheus Direct Scraping"
        SERVICEMONITORS[ServiceMonitors<br/>API Server<br/>Scheduler<br/>Controller Manager<br/>etcd<br/>Kubelet/cAdvisor<br/>Node Exporter<br/>Kube-State-Metrics<br/>CoreDNS<br/>Kube-Proxy]
    end

    subgraph "Storage Backends"
        TEMPO[Grafana Tempo<br/>Distributed Tracing]
        PROMETHEUS[Prometheus<br/>Time-Series DB<br/>system_* + container_*<br/>+ node_* + kube_*]
        LOKI[Grafana Loki<br/>Log Aggregation]
    end

    subgraph "Observability Frontend"
        GRAFANA[Grafana<br/>Unified Visualization<br/>Traces + Metrics + Logs]
    end

    subgraph "Pipelines"
        TRACE_PIPELINE[Traces Pipeline]
        METRICS_PIPELINE[Metrics Pipeline]
        LOGS_K8S_PIPELINE[Logs/K8s Pipeline]
        LOGS_K8S_EVENTS_PIPELINE[Logs/K8s Events Pipeline]
        LOGS_OS_PIPELINE[Logs/OpenStack Pipeline]
    end

