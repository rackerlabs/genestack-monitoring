    K8S_METRICS --> SERVICEMONITORS
    KUBELET --> SERVICEMONITORS
    NODE_EXPORTER --> SERVICEMONITORS
    KSM --> SERVICEMONITORS
    SERVICEMONITORS --> PROMETHEUS

    %% Logs K8s connections
    K8S_PODS --> FILELOG_K8S
    FILELOG_K8S --> LOGS_K8S_PIPELINE

    LOGS_K8S_PIPELINE --> MEMORY_LIMITER
    LOGS_K8S_PIPELINE --> K8S_ATTRS
    LOGS_K8S_PIPELINE --> BATCH
    LOGS_K8S_PIPELINE --> RESOURCE_DETECT
    LOGS_K8S_PIPELINE --> ATTRS
    LOGS_K8S_PIPELINE --> RESOURCE_LOKI

    LOGS_K8S_PIPELINE --> LOKI_EXP
    LOGS_K8S_PIPELINE --> DEBUG

    %% Logs K8s Events connections
    K8S_EVENTS --> K8SOBJECTS
    K8SOBJECTS --> LOGS_K8S_EVENTS_PIPELINE

    LOGS_K8S_EVENTS_PIPELINE --> MEMORY_LIMITER
    LOGS_K8S_EVENTS_PIPELINE --> RESOURCE_K8S_EVENTS
    LOGS_K8S_EVENTS_PIPELINE --> K8S_ATTRS
    LOGS_K8S_EVENTS_PIPELINE --> BATCH
    LOGS_K8S_EVENTS_PIPELINE --> RESOURCE_DETECT
    LOGS_K8S_EVENTS_PIPELINE --> ATTRS
    LOGS_K8S_EVENTS_PIPELINE --> RESOURCE_LOKI

    LOGS_K8S_EVENTS_PIPELINE --> LOKI_EXP
    LOGS_K8S_EVENTS_PIPELINE --> DEBUG

    %% Logs OpenStack connections
    OS_ALL --> FILELOG_OS

    FILELOG_OS --> LOGS_OS_PIPELINE

    LOGS_OS_PIPELINE --> MEMORY_LIMITER
    LOGS_OS_PIPELINE --> K8S_ATTRS
    LOGS_OS_PIPELINE --> BATCH
    LOGS_OS_PIPELINE --> ATTRS
    LOGS_OS_PIPELINE --> RESOURCE_OS
