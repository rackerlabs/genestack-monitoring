    LOGS_OS_PIPELINE --> LOKI_EXP
    LOGS_OS_PIPELINE --> DEBUG

    LOKI_EXP --> LOKI

    %% Storage to Grafana
    TEMPO --> GRAFANA
    PROMETHEUS --> GRAFANA
    LOKI --> GRAFANA

