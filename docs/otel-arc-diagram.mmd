graph TB
    subgraph "Data Sources"
        subgraph "Traces Sources"
            APP1[Applications with<br/>Auto-Instrumentation<br/>Java/Python/Node.js/.NET/Go]
            JAEGER_CLIENT[Jaeger Clients<br/>Legacy Apps]
            ZIPKIN_CLIENT[Zipkin Clients<br/>Legacy Apps]
            OTLP_CLIENT[OTLP Instrumented<br/>Applications]
        end

        subgraph "Metrics Sources"
            K8S_METRICS[Kubernetes Cluster<br/>API Server, Scheduler<br/>Controller Manager]
            KUBELET[Kubelet/cAdvisor<br/>Pod & Container Stats]
            NODE_EXPORTER[Node Exporter<br/>Host Metrics<br/>CPU/Memory/Disk/Network]
            KSM[Kube-State-Metrics<br/>K8s Object States]
            HOST[Host Metrics<br/>System Stats]
            PROM_TARGETS[Prometheus Targets<br/>Service Monitors]
        end

        subgraph "Logs Sources"
            K8S_PODS[Kubernetes Pods<br/>/var/log/pods/*/*/*.log]
            OS_NOVA[OpenStack Nova<br/>/var/log/nova/*.log]
            OS_NEUTRON[OpenStack Neutron<br/>/var/log/neutron/*.log]
            OS_CINDER[OpenStack Cinder]
            OS_KEYSTONE[OpenStack Keystone]
            OS_GLANCE[OpenStack Glance]
            OS_HORIZON[OpenStack Horizon]
            OS_HEAT[OpenStack Heat]
            OS_SWIFT[OpenStack Swift]
            OS_OCTAVIA[OpenStack Octavia]
            OS_PLACEMENT[OpenStack Placement]
            OS_MANILA[OpenStack Manila]
            OS_IRONIC[OpenStack Ironic]
            OS_BARBICAN[OpenStack Barbican]
            OS_CEILOMETER[OpenStack Ceilometer]
            OS_GNOCCHI[OpenStack Gnocchi]
            OS_SKYLINE[OpenStack Skyline]
            OS_TROVE[OpenStack Trove]
        end
    end

    subgraph "OpenTelemetry Collector DaemonSet"
        subgraph "Receivers Layer"
            subgraph "Trace Receivers"
                OTLP_GRPC[OTLP gRPC<br/>:4317]
                OTLP_HTTP[OTLP HTTP<br/>:4318]
                JAEGER_GRPC[Jaeger gRPC<br/>:14250]
                JAEGER_HTTP[Jaeger HTTP<br/>:14268]
                JAEGER_COMPACT[Jaeger Compact<br/>:6831]
                ZIPKIN[Zipkin<br/>:9411]
            end

            subgraph "Metrics Receivers"
                OTLP_METRICS[OTLP Receiver<br/>:4317/:4318]
                PROM_RECEIVER[Prometheus Receiver<br/>Scrape Config]
                HOSTMETRICS[Host Metrics<br/>Receiver]
                KUBELETSTATS[Kubelet Stats<br/>Receiver]
            end

            subgraph "Logs Receivers"
                FILELOG_K8S[filelog/k8s_containers<br/>Container Parser]
                FILELOG_NOVA[filelog/openstack_nova<br/>CRI + OpenStack Parser]
                FILELOG_NEUTRON[filelog/openstack_neutron]
                FILELOG_OTHERS[filelog/openstack_*<br/>14 more services...]
            end
        end

        subgraph "Processors Layer"
            MEMORY_LIMITER[Memory Limiter<br/>80% limit, 25% spike]
            BATCH[Batch Processor<br/>1024 batch size, 10s timeout]
            K8S_ATTRS[K8s Attributes<br/>Pod/Namespace/Node metadata]
            RESOURCE_DETECT[Resource Detection<br/>env, system, k8snode]
            RESOURCE_OS[Resource/OpenStack<br/>service.namespace=openstack]
            RESOURCE_K8S[Resource/K8s<br/>service.namespace=kube-system]
            ATTRS[Attributes Processor<br/>cluster name, environment]
        end

        subgraph "Exporters Layer"
            DEBUG[Debug Exporter<br/>Detailed verbosity<br/>Sampling 5/200]
            TEMPO_EXP[OTLP/Tempo<br/>tempo-distributor:4317]
            PROM_RW[Prometheus Remote Write<br/>prometheus-server/api/v1/write]
            PROM_EXP[Prometheus Exporter<br/>:8889]
            LOKI_EXP[OTLP HTTP/Loki<br/>loki-gateway/otlp]
        end
    end

    subgraph "Storage Backends"
        TEMPO[Grafana Tempo<br/>Distributed Tracing<br/>Backend]
        PROMETHEUS[Prometheus<br/>Time-Series Database<br/>Metrics Storage]
        LOKI[Grafana Loki<br/>Log Aggregation<br/>System]
    end

    subgraph "Observability Frontend"
        GRAFANA[Grafana<br/>Unified Visualization<br/>Dashboards & Alerts]
    end

    subgraph "Pipelines"
        TRACE_PIPELINE[Traces Pipeline<br/>receivers → processors → exporters]
        METRICS_PIPELINE[Metrics Pipeline<br/>receivers → processors → exporters]
        LOGS_K8S_PIPELINE[Logs/K8s Pipeline<br/>receivers → processors → exporters]
        LOGS_OS_PIPELINE[Logs/OpenStack Pipeline<br/>receivers → processors → exporters]
    end

